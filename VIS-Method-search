# MAIN
# =========================

def main():
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    PDF_DIR.mkdir(parents=True, exist_ok=True)

    all_records: List[Dict[str, Any]] = []

    print("Searching papers...")
    for query in QUERY_LIST:
        print(f"  - {query}")

        try:
            all_records.extend(search_semantic_scholar(query, MAX_RESULTS_PER_QUERY))
        except Exception as e:
            print(f"    Semantic Scholar error: {e}")

        if USE_SERPAPI_GOOGLE_SCHOLAR and SERPAPI_API_KEY:
            try:
                all_records.extend(search_google_scholar_serpapi(query, SERPAPI_API_KEY, num=100))
            except Exception as e:
                print(f"    Google Scholar / SerpAPI error: {e}")

        time.sleep(SLEEP_SECONDS)

    all_records = dedupe(all_records)

    filtered: List[Dict[str, Any]] = []
    for r in all_records:
        year = str(r.get("year", "")).strip()
        if year.isdigit() and int(year) < MIN_YEAR:
            continue

        score = score_text(r.get("title", ""), r.get("abstract", ""), r.get("venue", ""))
        r["relevance_score"] = score
        r["include_guess"] = include_guess(score)
        r["pdf_url"] = ""
        r["pdf_file"] = ""
        r["download_status"] = ""
        filtered.append(r)

    filtered.sort(
        key=lambda x: (
            x["include_guess"] != "yes",
            -x["relevance_score"],
            -safe_int(x.get("citation_count", 0), 0),
        )
    )

    # 下载 PDF
    if DOWNLOAD_PDFS:
        print("\nDownloading open-access PDFs...")
        download_count = 0
        for i, r in enumerate(filtered, start=1):
            if r["include_guess"] not in DOWNLOAD_ONLY_INCLUDE:
                continue
            if download_count >= MAX_DOWNLOADS:
                break

            pdf_url = choose_pdf_url(r)
            r["pdf_url"] = pdf_url

            if not pdf_url:
                r["download_status"] = "no_open_pdf_found"
                continue

            year = str(r.get("year", "") or "unknown")
            title = sanitize_filename(r.get("title", "untitled"))
            filename = f"{year} - {title}.pdf"
            out_path = PDF_DIR / filename

            # 避免重复下载
            if out_path.exists() and out_path.stat().st_size > 10_000:
                r["pdf_file"] = str(out_path)
                r["download_status"] = "already_exists"
                download_count += 1
                continue

            status = download_pdf(pdf_url, out_path)
            r["pdf_file"] = str(out_path) if out_path.exists() else ""
            r["download_status"] = status

            if status in {"downloaded", "already_exists"}:
                download_count += 1

            print(f"[{i}/{len(filtered)}] {r['include_guess']} | {status} | {r['title'][:80]}")
            time.sleep(SLEEP_SECONDS)

    # 写 CSV
    fieldnames = [
        "source",
        "query",
        "title",
        "year",
        "venue",
        "citation_count",
        "relevance_score",
        "include_guess",
        "doi",
        "paper_url",
        "semantic_open_pdf",
        "pdf_url",
        "pdf_file",
        "download_status",
        "is_open_access",
        "abstract",
    ]

    with open(CSV_PATH, "w", newline="", encoding="utf-8-sig") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(filtered)

    print("\nDone.")
    print(f"CSV saved to: {CSV_PATH}")
    print(f"PDF folder:    {PDF_DIR}")

    print("\nTop 20 results:")
    for r in filtered[:20]:
        print(
            f"[{r['include_guess']}] "
            f"score={r['relevance_score']} | "
            f"{r.get('year','')} | "
            f"{r['title']} | "
            f"{r['source']}"
        )

if __name__ == "__main__":
    main()