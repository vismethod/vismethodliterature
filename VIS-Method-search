# =========================
# HELPERS
# =========================

def normalize(text: Optional[str]) -> str:
    if not text:
        return ""
    text = text.lower().strip()
    text = re.sub(r"\s+", " ", text)
    return text

def sanitize_filename(name: str, max_len: int = 180) -> str:
    name = re.sub(r'[\\/*?:"<>|]', "_", name)
    name = re.sub(r"\s+", " ", name).strip()
    if len(name) > max_len:
        name = name[:max_len].rstrip()
    return name

def safe_int(v: Any, default: int = 0) -> int:
    try:
        return int(v)
    except Exception:
        return default

def score_text(title: str, abstract: str, venue: str = "") -> int:
    blob = normalize(" ".join([title or "", abstract or "", venue or ""]))
    score = 0

    for term, weight in POSITIVE_KEYWORDS.items():
        if term in blob:
            score += weight

    for term, weight in NEGATIVE_KEYWORDS.items():
        if term in blob:
            score += weight

    # 额外规则
    if "video" in blob and "visualization" in blob:
        score += 4
    if "interaction" in blob and ("qualitative" in blob or "interpretive" in blob):
        score += 4
    if "annotation" in blob and ("timeline" in blob or "sequence" in blob):
        score += 3
    if "mosaic" in blob or "keyframe" in blob:
        score += 3

    return score

def include_guess(score: int) -> str:
    if score >= 12:
        return "yes"
    if score >= 6:
        return "maybe"
    return "no"

def dedupe(records: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    seen = set()
    out = []
    for r in records:
        key = (
            normalize(r.get("title", "")),
            str(r.get("year", "")),
        )
        if key not in seen and key[0]:
            seen.add(key)
            out.append(r)
    return out

