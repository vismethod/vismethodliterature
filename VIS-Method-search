def search_semantic_scholar(query: str, limit: int = 20) -> List[Dict[str, Any]]:
    params = {
        "query": query,
        "limit": limit,
        "fields": ",".join([
            "title",
            "abstract",
            "year",
            "venue",
            "citationCount",
            "url",
            "externalIds",
            "openAccessPdf",
            "isOpenAccess",
        ])
    }
    resp = requests.get(
        SEMANTIC_SCHOLAR_URL,
        params=params,
        headers=HEADERS,
        timeout=REQUEST_TIMEOUT,
    )
    resp.raise_for_status()
    data = resp.json()

    results = []
    for item in data.get("data", []):
        external_ids = item.get("externalIds", {}) or {}
        open_access_pdf = item.get("openAccessPdf", {}) or {}

        results.append({
            "source": "Semantic Scholar",
            "query": query,
            "title": item.get("title", ""),
            "abstract": item.get("abstract", "") or "",
            "year": item.get("year", ""),
            "venue": item.get("venue", ""),
            "citation_count": item.get("citationCount", 0),
            "paper_url": item.get("url", ""),
            "doi": external_ids.get("DOI", ""),
            "semantic_open_pdf": open_access_pdf.get("url", "") if isinstance(open_access_pdf, dict) else "",
            "is_open_access": item.get("isOpenAccess", False),
        })
    return results

def extract_year_from_summary(text: str) -> str:
    if not text:
        return ""
    m = re.search(r"(20\d{2}|19\d{2})", text)
    return m.group(1) if m else ""

def extract_citation_count_serpapi(item: Dict[str, Any]) -> int:
    inline_links = item.get("inline_links", {}) or {}
    cited_by = inline_links.get("cited_by", {}) or {}
    return safe_int(cited_by.get("total", 0), 0)

def search_google_scholar_serpapi(query: str, api_key: str, num: int = 10) -> List[Dict[str, Any]]:
    results = []
    start = 0

    while True:
        params = {
            "engine": "google_scholar",
            "q": query,
            "num": num,
            "start": start,
            "api_key": api_key,
        }
        resp = requests.get(
            SERPAPI_URL,
            params=params,
            headers=HEADERS,
            timeout=REQUEST_TIMEOUT,
        )
        resp.raise_for_status()
        data = resp.json()

        organic = data.get("organic_results", [])
        if not organic:
            break

        for item in organic:
            publication_info = item.get("publication_info", {}) or {}
            summary = publication_info.get("summary", "") or ""
            resources = item.get("resources", []) or []

            pdf_link = ""
            for r in resources:
                if isinstance(r, dict):
                    link = r.get("link", "")
                    if link and ".pdf" in link.lower():
                        pdf_link = link
                        break

            results.append({
                "source": "Google Scholar (SerpAPI)",
                "query": query,
                "title": item.get("title", ""),
                "abstract": item.get("snippet", "") or "",
                "year": extract_year_from_summary(summary),
                "venue": summary,
                "citation_count": extract_citation_count_serpapi(item),
                "paper_url": item.get("link", ""),
                "doi": "",
                "semantic_open_pdf": pdf_link,
                "is_open_access": bool(pdf_link),
            })

        # 如果返回数量少于 num，说明已到最后一页
        if len(organic) < num:
            break

        start += num
        time.sleep(SLEEP_SECONDS)

    return results

# =========================
# OPEN ACCESS PDF LOOKUP
# =========================

def get_unpaywall_pdf_url(doi: str, email: str) -> str:
    if not doi or not email or "@" not in email:
        return ""
    url = f"{UNPAYWALL_URL}/{doi}"
    params = {"email": email}
    try:
        resp = requests.get(url, params=params, headers=HEADERS, timeout=REQUEST_TIMEOUT)
        if resp.status_code != 200:
            return ""
        data = resp.json()
        best = data.get("best_oa_location") or {}
        pdf_url = best.get("url_for_pdf") or ""
        if pdf_url:
            return pdf_url

        oa_locations = data.get("oa_locations") or []
        for loc in oa_locations:
            if not isinstance(loc, dict):
                continue
            pdf_url = loc.get("url_for_pdf") or ""
            if pdf_url:
                return pdf_url
        return ""
    except Exception:
        return ""

def choose_pdf_url(record: Dict[str, Any]) -> str:
    # 1) Semantic Scholar / Scholar 结果中已有 pdf 链接
    if record.get("semantic_open_pdf"):
        return record["semantic_open_pdf"]

    # 2) 用 DOI 去 Unpaywall 查 OA PDF
    doi = record.get("doi", "")
    pdf_url = get_unpaywall_pdf_url(doi, UNPAYWALL_EMAIL)
    if pdf_url:
        return pdf_url

    return ""

def download_pdf(pdf_url: str, out_path: Path) -> str:
    try:
        with requests.get(pdf_url, headers=HEADERS, timeout=REQUEST_TIMEOUT, stream=True) as r:
            if r.status_code != 200:
                return f"http_{r.status_code}"
            content_type = (r.headers.get("Content-Type") or "").lower()

            # 有些站点 content-type 不标准，所以不强制必须 application/pdf
            with open(out_path, "wb") as f:
                for chunk in r.iter_content(chunk_size=1024 * 64):
                    if chunk:
                        f.write(chunk)

        # 简单检查文件大小
        if out_path.exists() and out_path.stat().st_size > 10_000:
            return "downloaded"
        return "too_small"
    except Exception as e:
        return f"error: {type(e).__name__}"

