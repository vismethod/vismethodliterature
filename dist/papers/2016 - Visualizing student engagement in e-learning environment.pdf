  });
});</script></div><div class="right-rail--container"><script type="application/json" id="js-react-on-rails-context">{"componentRegistryTimeout":5000,"railsEnv":"production","inMailer":false,"i18nLocale":"en","i18nDefaultLocale":"en","rorVersion":"16.1.2","rorPro":true,"rorProVersion":"3.3.1","href":"https://www.academia.edu/54045043/Proceedings_of_the_22nd_International_Conference_on_Industrial_Engineering_and_Other_Applications_of_Applied_Intelligent_Systems_Next_Generation_Applied_Intelligence","location":"/54045043/Proceedings_of_the_22nd_International_Conference_on_Industrial_Engineering_and_Other_Applications_of_Applied_Intelligent_Systems_Next_Generation_Applied_Intelligence","scheme":"https","host":"www.academia.edu","port":null,"pathname":"/54045043/Proceedings_of_the_22nd_International_Conference_on_Industrial_Engineering_and_Other_Applications_of_Applied_Intelligent_Systems_Next_Generation_Applied_Intelligence","search":null,"httpAcceptLanguage":null,"autoProps":{},"serverSide":false}</script>
