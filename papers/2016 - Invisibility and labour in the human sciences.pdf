      <script>window.pageData = {
  highlighted_claims: null
}</script><script>window.loswp = {};
window.loswp.shouldDetectTimezone = true;
window.loswp.work = {"work":{"id":29420773,"created_at":"2016-10-25T13:04:42.121-07:00","from_world_paper_id":null,"updated_at":"2025-10-11T21:50:52.841-07:00","_data":{"ai_abstract":"This paper explores the interplay between invisibility and labour within the human sciences, specifically through the lens of historical research. Organized as a result of a workshop, the discussion underscores the politics of representation and challenges conventional narratives about citizen participation in scientific research. It highlights how the dynamics of visibility and invisibility manifest across three domains: people, power, and process, prompting a reevaluation of who is seen and how societal roles shape scientific knowledge production.","key_takeaways":"[\"The workshop explores themes of visibility and invisibility in the human sciences, particularly regarding labor and representation.\", \"Invisibility is dynamic, influenced by political and social contexts, affecting knowledge production and historical narratives.\", \"Translators and research assistants significantly shape knowledge production yet often remain unacknowledged in scholarly outputs.\", \"The gender dynamics in historical research reveal how women's contributions can become invisible or underappreciated.\", \"Historical practices of data collection, like those used for Roma populations, demonstrate how expertise can reinforce marginalization.\"]","publication_date":"2016,,","publication_name":"MPIWG Preprint [Max Planck Institute for the History of Science]"},"document_type":"paper","pre_hit_view_count_baseline":null,"quality":"high","language":"en","title":"Invisibility and labour in the human sciences","broadcastable":true,"draft":null,"has_indexable_attachment":true,"indexable":true,"seo_quality":9,"owner_type":"USER_OWNED"}}["work"];
