    });
  }

  faqQuestions.forEach((question) => {
    question.addEventListener('click', () => {
      const faqItem = question.closest('.work-faq--item');
      const faqNumber = faqItem?.dataset.faqNumber;

      if (faqNumber) {
        trackFaqClick(parseInt(faqNumber));
      }
    });
  });
});</script></details></div></div></div></div></div></div><div class="ungated-variant__right-panel"><div class="ungated-pdf-viewer-panel"><div class="floating-badges js-floating-badges" data-desktop-hidden-outline-ids="[&quot;title&quot;,&quot;abstract&quot;,&quot;key-takeaways&quot;,&quot;figures&quot;,&quot;faq&quot;]"><div class="floating-badges__panel js-floating-outline-panel hidden"><button aria-label="Close outline" class="floating-badges__close js-floating-outline-close" type="button"><span class="material-symbols-outlined">close</span></button><div class="floating-badges__outline-container"><div class="floating-badges__progress-container"><div class="floating-badges__progress-line js-floating-progress-line"></div></div><div class="floating-badges__elements"><div class="floating-badges__element js-floating-outline-element-title" data-target-id="title"><div class="floating-badges__dot"></div><a class="floating-badges__link js-floating-outline-item js-loswp-outline-link" data-element-name="Title" href="#title">Title</a></div><div class="floating-badges__element js-floating-outline-element-abstract" data-target-id="abstract"><div class="floating-badges__dot"></div><a class="floating-badges__link js-floating-outline-item js-loswp-outline-link" data-element-name="Abstract" href="#abstract">Abstract</a></div><div class="floating-badges__element js-floating-outline-element-key-takeaways" data-target-id="key-takeaways"><div class="floating-badges__dot"></div><a class="floating-badges__link js-floating-outline-item js-loswp-outline-link" data-element-name="Key Takeaways" href="#key-takeaways">Key Takeaways</a></div><div class="floating-badges__element js-floating-outline-element-faq" data-target-id="faq"><div class="floating-badges__dot"></div><a class="floating-badges__link js-floating-outline-item js-loswp-outline-link" data-element-name="FAQs" href="#faq">FAQs</a></div><div class="floating-badges__element js-floating-outline-element-outer_page_77" data-target-id="