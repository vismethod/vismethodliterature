<div id="AboutTheAuthorsSSR-react-component-6e0d442d-f1bb-4bb6-a165-454fe0dcdb44"><div class="AboutTheAuthorsSSR-cls2_Yk9 AboutTheAuthorsSSR-cls1_c2J"><section style="gap:var(--spacing-xs-16, 16px)" class="SidebarSection-cls2_48y SidebarSection-cls1_sjk"><header class="SidebarSection-cls2_y03 SidebarSection-cls1_08-">About the author</header><div class="UserCard-cls2_j80 UserCard-cls1_lJx"><img src="https://0.academia-photos.com/676229/7921186/28843991/s65_alexandre.campelo.jpg" width="48" height="48" class="UserAvatar-cls2_NlM UserAvatar-cls1_C6Z"/><div class="UserCard-cls2_lsu UserCard-cls1_3Lh"><div class="UserCard-cls2_7GZ UserCard-cls1_OMn"><a href="https://unesp.academia.edu/AlexandreCampelo" class="ds2-5-body-md ds2-5-body-link">Alexandre Campelo</a></div><div class="UserCard-cls2_dRF UserCard-cls1_6gN">Universidade Estadual Paulista &quot;Júlio de Mesquita Filho&quot;, Department Member</div><div class="UserCard-cls2_W7U UserCard-cls1_3FG"><div class="AuthorCard-cls2_ZvH AuthorCard-cls1_M61"><button class="ds2-5-text-link ds2-5-text-link--inline"><span class="material-symbols-outlined" style="font-size:20px" translate="no">add</span><span class="ds2-5-text-link__content">Follow</span></button><button class="ds2-5-text-link ds2-5-text-link--inline"><span class="material-symbols-outlined" style="font-size:20px" translate="no">mail</span><span class="ds2-5-text-link__content">Message</span></button></div></div></div></div><div class="AboutTheAuthorsSection-cls2_m7J AboutTheAuthorsSection-cls1_8jj"><div class="ds2-5-stat--basic-small"><div class="ds2-5-stat--basic-small__label">Papers</div><div class="ds2-5-stat--basic-small__value">12</div></div><div class="ds2-5-stat--basic-small"><div class="ds2-5-stat--basic-small__label">Followers</div><div class="ds2-5-stat--basic-small__value">153</div></div></div><a href="https://unesp.academia.edu/AlexandreCampelo" class="AboutTheAuthorsSection-cls2_A6v AboutTheAuthorsSection-cls1_hRN"><span class="AboutTheAuthorsSectio