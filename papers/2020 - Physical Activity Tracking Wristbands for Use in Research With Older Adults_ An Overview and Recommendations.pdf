    throw 'click tracking disabled due to missing CSRF token (text button link)';
  }

  const options = {"source":"loswp--wsj-grid-card-download-pdf-modal","bucket":"outline","entity_id":80978933,"extra":{"source_work_id":80978933}};
  const button = document.querySelector('.js-tc-loswp--wsj-grid-card-download-pdf-modal');
